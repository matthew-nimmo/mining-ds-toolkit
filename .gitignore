# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Folders
**/release/
**/.Rproj/

# Files
.DS_Store
.Rhistory
.Rproj.user
/tools-gui/dps/.quarto
/tools-gui/dps/_targets
/tools-gui/dps/_targets_r
/tools-gui/dps/data/NEQ
tools-gui/dps/_targets.R
tools-gui/dps/dps_shiny.html
/tools-gui/dps/dps_shiny_files
