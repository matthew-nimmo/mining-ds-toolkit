      "preserve14897a32100bec57": "\n<script type=\"application/shiny-prerendered\" data-context=\"server-extras\">\nojs_define <- function(..., .session = shiny::getDefaultReactiveDomain()) {\n  quos <- rlang::enquos(...)\n  vars <- rlang::list2(...)\n  nm <- names(vars)\n  if (is.null(nm)) {\n    nm <- rep_len(\"\", length(vars))\n  }\n  mapply(\n    function(q, nm, val) {\n      # Infer name, if possible\n      if (nm == \"\") {\n        tryCatch(\n          {\n            nm <- rlang::as_name(q)\n          },\n          error = function(e) {\n            code <- paste(collapse = \"\\n\", deparse(rlang::f_rhs(q)))\n            stop(\n              \"ojs_define() could not create a name for the argument: \",\n              code\n            )\n          }\n        )\n      }\n      .session$output[[nm]] <- val\n      outputOptions(.session$output, nm, suspendWhenHidden = FALSE)\n      .session$sendCustomMessage(\"ojs-export\", list(name = nm))\n      NULL\n    },\n    quos,\n    nm,\n    vars,\n    SIMPLIFY = FALSE,\n    USE.NAMES = FALSE\n  )\n  invisible()\n}\n</script>\n",
      "preserve2c1bc878eebb427e": "\n<script type=\"application/shiny-prerendered\" data-context=\"server\">\noutput$file_name = renderUI({\n  if (input$file_class == \"all\") {\n    x <- c(unique(df$file_name))\n  } else {\n    x <- c(unique(df$file_name[df$file_class == input$file_class]))\n  }\n  selectInput(\"file_name\", \"File Name:\", x, size=1, selectize=FALSE)\n})\n\noutput$sheet_name = renderUI({\n  x <- c(unique(df$sheet_name[df$file_name == input$file_name]))\n  x <- ifelse(is.na(x), \"none\", x)\n  selectInput(\"sheet_name\", \"Sheet Name\", x, size=1, selectize=FALSE)\n})\n\nidx <- reactive({\n  x <- df\n  if (input$file_name != \"none\") {\n    x <- x[x$file_name == input$file_name,]\n  }\n  if (input$sheet_name != \"none\") {\n    x <- x[x$sheet_name == input$sheet_name,]\n  }\n  n <- c(head(x$id, 1), head(x$sheet_num, 1))\n  return(n)\n})\n\noutput$fields <- renderTable({\n  n <- idx()\n  if (!any(is.na(n))) {\n    if (input$show_all) {\n      x <- df[, c(\"file_name\",\"id\",\"sheet_num\",\"sheet_name\")] |>\n        merge(profile_field)\n    } else {\n      x <- profile_field[profile_field$id==n[1] & profile_field$sheet_num==n[2],]\n    }\n    x <- x[grepl(input$filter, x$field), ]\n  } else {\n    x <- NULL\n  }\n  return(x)\n})\n\noutput$class <- renderText({\n  n <- idx()\n  if (!any(is.na(n))) {\n    x <- df$file_class[df$id==n[1] & df$sheet_num==n[2]]\n  } else {\n    x <- \"none\"\n  }\n  return(x)\n})\n\noutput$sim_files <- renderText({\n  n <- idx()\n  if (!any(is.na(n))) {\n    x <- df$file_cluster[df$id==n[1] & df$sheet_num==n[2]]\n    j <- df$file_cluster == x\n    x <- df$file_path[j]\n    x <- sub(dqs_client_files, \".\", x)\n    if (length(x) > 1) {\n      x <- data.frame(pathString = x) |>\n        as.Node(x)\n      x <- capture.output(print(x))\n      x <- x[-1]\n      x <- sub(\"^[[:digit:]]+[[:space:]]+\", \"\", x)\n      x <- paste(x, collapse=\"\\n\")\n    } else {\n      x <- \"none\"\n    }\n  } else {\n    x <- \"none\"\n  }\n  return(x)\n})\n</script>\n",
      "preserve3721b2e9268e7db7": "\n<script type=\"application/shiny-prerendered\" data-context=\"server\">\ndf_x <- reactive({\n  x <- df\n  x <- x[x$file_class %in% input$include_class, ]\n  return(x)\n})\n\nn <- reactive({\n  x <- df_x()\n  flds <- c(\"accessibility\", \"completeness\", \"complexity\",\n            \"consistency\",\"metadata\", \"skewness\", \"uniqueness\", \"usability\")\n  x <- sapply(x[, flds], mean, na.rm=TRUE)\n  x <- signif(100 * mean(x), 3)\n  return(x)\n})\n\noutput$score_card <- renderText({ n() })\n\noutput$hist_scores <- renderPlot({\n  x <- df_x()\n  ggplot(x, aes(x=score)) +\n    geom_histogram()\n})\n\noutput$box_scores <- renderPlot({\n  x <- df_x()\n  ggplot(x, aes(x=score)) +\n    geom_boxplot()\n})\n\noutput$radar <- renderPlot({\n  x <- c(\"accessibility\", \"completeness\", \"complexity\", \"consistency\",\n        \"metadata\", \"skewness\", \"uniqueness\", \"usability\")\n  x <- sapply(df_x()[, x], mean, na.rm=TRUE)\n  x <- c(mean(x), x)\n  x <- t(data.frame(score = x))\n  ggradar(x, plot.extent.x.sf=1.2, plot.extent.y.sf=1.2, group.point.size=2)\n})\n\noutput$ridges <- renderPlot({\n  x <- df_x()[, c(\"accessibility\",\"metadata\",\"completeness\",\n                  \"complexity\",\"consistency\",\"skewness\",\"uniqueness\",\n                  \"usability\")] |>\n  stack()\n  ggplot(x, aes(x=values, y=ind, fill = ..x..)) +\n    geom_density_ridges_gradient(scale = 3, rel_min_height = 0.01) +\n    scale_fill_viridis(option = \"C\") +\n    xlab(\"score\") +\n    ylab(\"\") +\n    theme(legend.position=\"none\",\n          panel.spacing = unit(0.1, \"lines\"),\n          strip.text.x = element_text(size = 8))\n})\n\noutput$scores <- renderTable({\n  x <- df_x() |>\n    dplyr::select(all_of(c(\"file_name\",\"file_ext\",\"sheet_name\",\"score\",\n                           \"accessibility\",\"metadata\",\"completeness\",\n                           \"complexity\",\"consistency\",\"skewness\",\n                           \"uniqueness\",\"usability\"))) |>\n    dplyr::arrange(score)\n  return(x)\n})\n</script>\n",
      "preserved33ef9af1aec111d": "\n<script type=\"application/shiny-prerendered\" data-context=\"server-start\">\nSys.setenv(`_R_USE_PIPEBIND_` = TRUE)\nlibrary(targets)\nlibrary(RSQLite)\nlibrary(bslib)\nlibrary(bsicons)\nlibrary(ggplot2)\nlibrary(ggridges)\nlibrary(ggradar)\nlibrary(viridis)\nlibrary(data.tree)\n\n#devtools::install_github(\"ricardo-bion/ggradar\", dependencies = TRUE)\n\ntar_load(dqs_client_files)\ntar_load(dqs_db_file)\n\ndqs_db_file <- paste0(dqs_db_file, \".sqlite\")\n\ncon <- dbConnect(SQLite(), dqs_db_file)\n\ndataset <- dbReadTable(con, \"dataset\")\ndatafiles <- dbReadTable(con, \"datafiles\")\nprofile_field <- dbReadTable(con, \"profile_field\")\nprofile_table <- dbReadTable(con, \"profile_table\")\ndbDisconnect(con)\n\ndf <- dataset |>\n  dplyr::filter(data_type == \"data\") |>\n  dplyr::mutate(file_name = basename(file_path)) |>\n  dplyr::select(all_of(c(\"id\",\"file_path\",\"file_name\",\"file_ext\",\"file_size\",\n                         \"data_type\",\"file_set\",\"duplicated\",\"include\")))\ndf$n <- 1:nrow(df)\ndf <- merge(df, datafiles, by=\"id\") |>\n  dplyr::filter(type != \"unknwn\")\n\nx <- c(\"accessibility\", \"completeness\", \"complexity\", \"consistency\",\n       \"metadata\", \"skewness\", \"uniqueness\", \"usability\")\nx <- apply(df[, x], 1, mean, na.rm=TRUE)\ndf$score <- x\n</script>\n"
